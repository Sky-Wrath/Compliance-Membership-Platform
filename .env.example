# Environment
NODE_ENV=development
PORT=3000

# Frontend
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
WEBSOCKET_URL=ws://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/compliance_db
DATABASE_REPLICA_URL=postgresql://postgres:password@localhost:5432/compliance_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h

# Encryption
ENCRYPTION_KEY_VERSION_1=base64_encoded_32byte_key_here
ENCRYPTION_KEY_CURRENT=1
ENCRYPTION_ALGORITHM=aes-256-gcm

# CCBill Payment
CCBILL_WEBHOOK_SECRET=your_ccbill_webhook_secret
CCBILL_API_KEY=your_ccbill_api_key
CCBILL_MERCHANT_ID=your_merchant_id

# KYC Verification
KYC_PROVIDER_API_KEY=your_kyc_provider_key
KYC_PROVIDER_ENDPOINT=https://api.kyc-provider.com
KYC_VERIFICATION_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your_session_secret
SESSION_TIMEOUT=3600000
